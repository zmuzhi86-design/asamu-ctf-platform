APP_ENV=development
HTTP_ADDR=:8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
WEB_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
COOKIE_SECURE=false

DATABASE_URL=postgres://asamu:change-me@postgres:5432/asamu?sslmode=disable
DATABASE_MAX_OPEN=25
DATABASE_MAX_IDLE=5
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM=asamu.runtime.jobs
REDIS_CONSUMER_GROUP=asamu-workers

JWT_ISSUER=asamu-platform
JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=720h
FLAG_HMAC_SECRET=replace-with-at-least-32-random-bytes
FLAG_ENCRYPTION_KEY_BASE64=replace-with-base64-encoded-32-byte-key
REGISTRY_CREDENTIAL_ENCRYPTION_KEY_BASE64=replace-with-an-independent-base64-encoded-32-byte-key
CONFIRMATION_TOKEN_SECRET=replace-with-at-least-32-random-bytes

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./var/storage

RUNTIME_PROVIDER=docker
RUNTIME_PUBLIC_HOST=127.0.0.1
RUNTIME_BIND_HOST=127.0.0.1
RUNTIME_BASE_DOMAIN=challenge.localhost
RUNTIME_PORT_MIN=20000
RUNTIME_PORT_MAX=30000
RUNTIME_WORKER_ID=asamu-runtime-worker
RUNTIME_WORKER_INTERNAL_API_URL=http://api:8787/api/v1
RUNTIME_WORKER_API_TOKEN=replace-with-at-least-32-random-bytes-when-runtime-is-enabled
RUNTIME_WORKER_CPU_MILLI=4000
RUNTIME_WORKER_MEMORY_MB=8192
RUNTIME_WORKER_MAX_INSTANCES=50
RUNTIME_WORKER_PROTOCOLS=http,tcp,udp
RUNTIME_DEFAULT_TTL=2h
RUNTIME_MAX_TTL=4h
RUNTIME_ALLOWED_IMAGES=asamu/sqli-lab:dev
RUNTIME_PULL_MISSING_IMAGES=false
DEFAULT_CHALLENGE_IMAGE=asamu/sqli-lab:dev
DEFAULT_CHALLENGE_INTERNAL_PORT=8080
SEED_DEMO_CONTENT=true
RUNTIME_DOCKER_HOST=

RATE_LIMIT_RPS=15
RATE_LIMIT_BURST=30
DOCS_ENABLED=true

DEV_ADMIN_EMAIL=
DEV_ADMIN_USERNAME=
DEV_ADMIN_PASSWORD=
DEV_USER_EMAIL=
DEV_USER_USERNAME=
DEV_USER_PASSWORD=
