# 可选：Docker Hub 无法访问时，替换为国内镜像完整地址。
# POSTGRES_IMAGE=m.daocloud.io/docker.io/library/postgres:16-alpine
# REDIS_IMAGE=m.daocloud.io/docker.io/library/redis:7.2-alpine
# GO_BUILD_IMAGE=m.daocloud.io/docker.io/library/golang:1.25.12-alpine3.24
# ALPINE_BASE_IMAGE=m.daocloud.io/docker.io/library/alpine:3.24
# NODE_BUILD_IMAGE=m.daocloud.io/docker.io/library/node:22.18-alpine3.22
# NGINX_BASE_IMAGE=m.daocloud.io/docker.io/library/nginx:1.28-alpine

ASAMU_DEPLOY_VERSION=8
ASAMU_LOCAL_BUILD=false
APP_VERSION=0.3.1
API_IMAGE=registry.example.com/asamu/api
WEB_IMAGE=registry.example.com/asamu/web
WORKER_IMAGE=registry.example.com/asamu/runtime-worker
BUILDKIT_IMAGE=moby/buildkit:v0.23.2-rootless
TRAEFIK_IMAGE=traefik:v3.5.0
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
APP_ENV=production
HTTP_ADDR=:8787
HTTP_PORT=8080
PUBLIC_BASE_URL=http://SERVER_IP:8080
WEB_ORIGINS=http://SERVER_IP:8080
COOKIE_SECURE=false

POSTGRES_PASSWORD=replace-with-random-password
POSTGRES_USER=asamu
POSTGRES_DB=asamu
POSTGRES_VOLUME_NAME=asamu_postgres-data
REDIS_VOLUME_NAME=asamu_redis-data
ASSET_VOLUME_NAME=asamu_asset-data
BUILDKIT_VOLUME_NAME=asamu_buildkit-state
DATABASE_URL=postgres://asamu:replace-with-random-password@postgres:5432/asamu?sslmode=disable
DATABASE_MAX_OPEN=40
DATABASE_MAX_IDLE=10

REDIS_PASSWORD=replace-with-random-password
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_STREAM=asamu.runtime.jobs
REDIS_CONSUMER_GROUP=asamu-workers

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/app/var/storage

JWT_ISSUER=asamu-platform
JWT_ACCESS_SECRET=replace-with-32-or-more-random-bytes
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=720h
FLAG_HMAC_SECRET=replace-with-32-or-more-random-bytes
FLAG_ENCRYPTION_KEY_BASE64=replace-with-base64-encoded-32-byte-key
REGISTRY_CREDENTIAL_ENCRYPTION_KEY_BASE64=replace-with-an-independent-base64-encoded-32-byte-key
CONFIRMATION_TOKEN_SECRET=replace-with-32-or-more-random-bytes

# 离线演示可使用 log（仅记录收件人和模板，不打印令牌）；生产建议配置 smtp。
MAIL_DRIVER=log
MAIL_FROM=noreply@asamu.local
MAIL_PUBLIC_BASE_URL=http://SERVER_IP:8080
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_POLL_INTERVAL=2s

# 网站模式：不启动题目 Worker，不要求题目镜像。
RUNTIME_PROVIDER=docker
RUNTIME_ENABLED=false
RUNTIME_PUBLIC_HOST=SERVER_IP
RUNTIME_BIND_HOST=127.0.0.1
RUNTIME_PORT_MIN=20000
RUNTIME_PORT_MAX=30000
# 留空时只运行宿主机已存在的本地镜像；启用自动拉取时填写允许的远程镜像列表。
RUNTIME_ALLOWED_IMAGES=
RUNTIME_PULL_MISSING_IMAGES=false
RUNTIME_WORKER_ID=asamu-runtime-worker
RUNTIME_WORKER_INTERNAL_API_URL=http://api:8787/api/v1
RUNTIME_WORKER_API_TOKEN=replace-with-32-or-more-random-bytes
RUNTIME_WORKER_CPU_MILLI=4000
RUNTIME_WORKER_MEMORY_MB=8192
RUNTIME_WORKER_MAX_INSTANCES=50
RUNTIME_WORKER_PROTOCOLS=http,tcp,udp
SEED_DEMO_CONTENT=false

RATE_LIMIT_RPS=15
RATE_LIMIT_BURST=30
DOCS_ENABLED=false

DEV_ADMIN_EMAIL=admin@asamu.local
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=replace-with-a-strong-password
DEV_USER_EMAIL=student@asamu.local
DEV_USER_USERNAME=student
DEV_USER_PASSWORD=replace-with-a-strong-password
